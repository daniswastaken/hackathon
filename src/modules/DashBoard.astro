---
/* eslint max-lines: 'off' */

import { asset } from '../lib/data';
---

<div class="px-4 pt-6 space-y-6 pb-12">
    <!-- Stats Row -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
        <div class="p-4 bg-white border border-gray-200 rounded-lg shadow-sm dark:bg-gray-800 dark:border-gray-700">
            <h3 class="text-base font-normal text-gray-500 dark:text-gray-400">Total Portions Rescued</h3>
            <span id="stat-rescued" class="text-2xl font-bold text-gray-900 dark:text-white">...</span>
        </div>
        <div class="p-4 bg-white border border-gray-200 rounded-lg shadow-sm dark:bg-gray-800 dark:border-gray-700">
            <h3 class="text-base font-normal text-gray-500 dark:text-gray-400">Active Schools</h3>
            <span id="stat-schools" class="text-2xl font-bold text-gray-900 dark:text-white">...</span>
        </div>
        <div class="p-4 bg-white border border-gray-200 rounded-lg shadow-sm dark:bg-gray-800 dark:border-gray-700">
            <h3 class="text-base font-normal text-gray-500 dark:text-gray-400">Rescue Posts</h3>
            <span id="stat-posts" class="text-2xl font-bold text-gray-900 dark:text-white">...</span>
        </div>
    </div>

	<!-- Analytics Section -->
	<div class="flex items-center justify-between border-b border-gray-200 dark:border-gray-700 pb-2">
		<h2 class="text-2xl font-extrabold text-gray-900 dark:text-white uppercase tracking-tight">Rescue Analytics</h2>
		<span class="bg-primary-100 text-primary-800 text-xs font-semibold px-2.5 py-0.5 rounded dark:bg-primary-900 dark:text-primary-300">Activity Report</span>
	</div>

	<div class="grid grid-cols-1 xl:grid-cols-2 gap-4">
		<!-- Main area chart -->
		<div class="p-4 bg-white border border-gray-200 rounded-lg shadow-sm dark:border-gray-700 sm:p-6 dark:bg-gray-800">
			<div id="main-chart" class="min-h-[420px]"></div>
		</div>

		<!-- Leaderboard Tabs -->
		<div class="p-4 bg-white border border-gray-200 rounded-lg shadow-sm dark:border-gray-700 sm:p-6 dark:bg-gray-800">
			<h3 class="mb-4 text-lg font-semibold text-gray-900 dark:text-white uppercase tracking-wider">Top Contributors</h3>
			<!-- ... existing leaderboard code ... -->
		</div>
	</div>
</div>

<script>
    async function updateStats() {
        try {
            const res = await fetch('/api/stats');
            const data = await res.json();
            document.getElementById('stat-rescued').textContent = (data.total_portions || 0) + ' portions';
            document.getElementById('stat-schools').textContent = data.active_schools || 0;
            document.getElementById('stat-posts').textContent = data.total_rescues || 0;
        } catch (err) {
            console.error('Failed to load stats', err);
        }
    }
    updateStats();
</script>

<script src="./DashBoard.client.ts"></script>

<style is:global>
	#main-chart {
		min-height: 420px;
	}
	.apexcharts-canvas {
		user-select: none;
	}
</style>
