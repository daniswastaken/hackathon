---
/* eslint max-lines: 'off' */

import { asset } from '../lib/data';

let dashData: any = {
	totalRescued: 0,
	topSchools: [],
	topVolunteers: [],
	activeSchools: 0,
	totalVolunteers: 0,
	chartData: null,
	growthPercentage: 0
};

try {
	const db = (Astro.locals as any)?.runtime?.env?.DB;
	if (db) {
		const { results: totalRescuedRaw } = await db.prepare(`SELECT SUM(quantity_portions) as total FROM food_listings`).all();
		dashData.totalRescued = totalRescuedRaw[0]?.total || 0;

		const { results: recentRescuedRaw } = await db.prepare(`SELECT SUM(quantity_portions) as total FROM food_listings WHERE created_at >= date('now', '-7 days')`).all();
		const { results: pastRescuedRaw } = await db.prepare(`SELECT SUM(quantity_portions) as total FROM food_listings WHERE created_at >= date('now', '-14 days') AND created_at < date('now', '-7 days')`).all();
		const recent = recentRescuedRaw[0]?.total || 0;
		const past = pastRescuedRaw[0]?.total || 0;
		dashData.growthPercentage = past > 0 ? ((recent - past) / past) * 100 : (recent > 0 ? 100 : 0);

		const { results: topSchools } = await db.prepare(`
			SELECT u.id, u.name, u.organization, SUM(f.quantity_portions) as total_rescued
			FROM users u LEFT JOIN food_listings f ON u.id = f.provider_id
			WHERE u.role = 'provider' GROUP BY u.id ORDER BY total_rescued DESC LIMIT 5
		`).all();
		dashData.topSchools = topSchools;

		const { results: topVolunteers } = await db.prepare(`
			SELECT id, name, email, avatar, points FROM users WHERE role = 'receiver' ORDER BY points DESC LIMIT 5
		`).all();
		dashData.topVolunteers = topVolunteers;

		const { results: activeSchoolsRaw } = await db.prepare(`SELECT COUNT(id) as total FROM users WHERE role = 'provider'`).all();
		dashData.activeSchools = activeSchoolsRaw[0]?.total || 0;

		const { results: totalVolunteersRaw } = await db.prepare(`SELECT COUNT(id) as total FROM users WHERE role = 'receiver'`).all();
		dashData.totalVolunteers = totalVolunteersRaw[0]?.total || 0;

		// Chart data
		const { results: foodHistoryRaw } = await db.prepare(`
			SELECT date(created_at) as dt, category, SUM(quantity_portions) as total
			FROM food_listings WHERE created_at >= date('now', '-6 days') GROUP BY dt, category
		`).all();
		const { results: userHistoryRaw } = await db.prepare(`
			SELECT date(created_at) as dt, role, COUNT(id) as total
			FROM users WHERE created_at >= date('now', '-6 days') GROUP BY dt, role
		`).all();

		const chartData: any = { labels: [], consumable: [], farm: [], newSchools: [], newVolunteers: [] };
		for (let i = 6; i >= 0; i--) {
			const d = new Date(); d.setDate(d.getDate() - i);
			const dtStr = d.toISOString().split('T')[0];
			const displayStr = d.toLocaleDateString('en-GB', { day: '2-digit', month: 'short' });
			chartData.labels.push(displayStr);
			chartData.consumable.push(Number(foodHistoryRaw.find((r:any) => r.dt === dtStr && (r.category === 'consumable' || r.category === 'Consumable'))?.total || 0));
			chartData.farm.push(Number(foodHistoryRaw.find((r:any) => r.dt === dtStr && (r.category === 'farm' || r.category === 'Farm/Fertilizer'))?.total || 0));
			chartData.newSchools.push(Number(userHistoryRaw.find((r:any) => r.dt === dtStr && r.role === 'provider')?.total || 0));
			chartData.newVolunteers.push(Number(userHistoryRaw.find((r:any) => r.dt === dtStr && r.role === 'receiver')?.total || 0));
		}
		dashData.chartData = chartData;
	}
} catch (e) {
	console.error('Dashboard DB error:', e);
}
---

<div class="px-4 pt-6">
	<div class="grid gap-4 xl:grid-cols-2 2xl:grid-cols-3">
		<!-- Main widget -->
		<div class="p-4 bg-white border border-gray-200 rounded-lg shadow-sm 2xl:col-span-2 dark:border-gray-700 sm:p-6 dark:bg-gray-800">
			<div class="flex items-center justify-between mb-4">
				<div class="flex-shrink-0">
					<span class="text-xl font-bold leading-none text-gray-900 sm:text-2xl dark:text-white">{dashData.totalRescued.toLocaleString()}</span>
					<h3 class="text-base font-light text-gray-500 dark:text-gray-400">Total portions rescued</h3>
				</div>
				<div class={`flex items-center justify-end flex-1 text-base font-medium ${dashData.growthPercentage >= 0 ? 'text-green-500 dark:text-green-400' : 'text-red-500 dark:text-red-400'}`}>
					{Math.abs(dashData.growthPercentage).toFixed(1)}%
					{dashData.growthPercentage >= 0 ? (
						<svg class="w-5 h-5" fill="currentColor" viewBox="0 0 20 20" xmlns="http://www.w3.org/2000/svg">
							<path fill-rule="evenodd" d="M5.293 7.707a1 1 0 010-1.414l4-4a1 1 0 011.414 0l4 4a1 1 0 01-1.414 1.414L11 5.414V17a1 1 0 11-2 0V5.414L6.707 7.707a1 1 0 01-1.414 0z" clip-rule="evenodd"></path>
						</svg>
					) : (
						<svg class="w-5 h-5" fill="currentColor" viewBox="0 0 20 20" xmlns="http://www.w3.org/2000/svg">
							<path fill-rule="evenodd" d="M14.707 12.293a1 1 0 010 1.414l-4 4a1 1 0 01-1.414 0l-4-4a1 1 0 111.414-1.414L9 14.586V3a1 1 0 012 0v11.586l2.293-2.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
						</svg>
					)}
				</div>
			</div>

			<div id="main-chart"></div>

			<!-- Card Footer -->
			<div class="flex items-center justify-between pt-3 mt-4 border-t border-gray-200 sm:pt-6 dark:border-gray-700">
				<div>
					<button class="inline-flex items-center p-2 text-sm font-medium text-center text-gray-500 rounded-lg hover:text-gray-900 dark:text-gray-400 dark:hover:text-white" type="button" data-dropdown-toggle="weekly-sales-dropdown">Last 7 days <svg class="w-4 h-4 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path></svg></button>
					<div class="z-50 hidden my-4 text-base list-none bg-white divide-y divide-gray-100 rounded shadow dark:bg-gray-700 dark:divide-gray-600" id="weekly-sales-dropdown">
						<div class="px-4 py-3" role="none"><p class="text-sm font-medium text-gray-900 truncate dark:text-white" role="none">May 16, 2026 - May 22, 2026</p></div>
						<ul class="py-1" role="none">
							<li><a href="#" class="block px-4 py-2 text-sm text-gray-700 hover:bg-gray-100 dark:text-gray-400 dark:hover:bg-gray-600 dark:hover:text-white" role="menuitem">Yesterday</a></li>
							<li><a href="#" class="block px-4 py-2 text-sm text-gray-700 hover:bg-gray-100 dark:text-gray-400 dark:hover:bg-gray-600 dark:hover:text-white" role="menuitem">Today</a></li>
							<li><a href="#" class="block px-4 py-2 text-sm text-gray-700 hover:bg-gray-100 dark:text-gray-400 dark:hover:bg-gray-600 dark:hover:text-white" role="menuitem">Last 7 days</a></li>
						</ul>
					</div>
				</div>
				<div class="flex-shrink-0">
					<a href="#" class="inline-flex items-center p-2 text-xs font-medium uppercase rounded-lg text-primary-700 sm:text-sm hover:bg-gray-100 dark:text-primary-500 dark:hover:bg-gray-700">
						Full Report
						<svg class="w-4 h-4 ml-1" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path></svg>
					</a>
				</div>
			</div>
		</div>

		<!--Tabs widget -->
		<div class="p-4 bg-white border border-gray-200 rounded-lg shadow-sm dark:border-gray-700 sm:p-6 dark:bg-gray-800">
			<h3 class="flex items-center mb-4 text-lg font-semibold text-gray-900 dark:text-white">Rescue Statistics</h3>
			<div class="sm:hidden">
				<label for="tabs" class="sr-only">Select tab</label>
				<select id="tabs" class="bg-gray-50 border-0 border-b border-gray-200 text-gray-900 text-sm rounded-t-lg focus:ring-primary-500 focus:border-primary-500 block w-full p-2.5 dark:bg-gray-700 dark:border-gray-600 dark:placeholder-gray-400 dark:text-white dark:focus:ring-primary-500 dark:focus:border-primary-500">
					<option>Top Schools</option>
					<option>Top Volunteers</option>
				</select>
			</div>
			<ul class="hidden text-sm font-medium text-center text-gray-500 divide-x divide-gray-200 rounded-lg sm:flex dark:divide-gray-600 dark:text-gray-400" id="fullWidthTab" data-tabs-toggle="#fullWidthTabContent" role="tablist">
				<li class="w-full"><button id="faq-tab" data-tabs-target="#faq" type="button" role="tab" class="inline-block w-full p-4 rounded-tl-lg bg-gray-50 hover:bg-gray-100 focus:outline-none dark:bg-gray-700 dark:hover:bg-gray-600">Top Schools</button></li>
				<li class="w-full"><button id="about-tab" data-tabs-target="#about" type="button" role="tab" class="inline-block w-full p-4 rounded-tr-lg bg-gray-50 hover:bg-gray-100 focus:outline-none dark:bg-gray-700 dark:hover:bg-gray-600">Top Volunteers</button></li>
			</ul>
			<div id="fullWidthTabContent" class="border-t border-gray-200 dark:border-gray-600">
				<div class="hidden pt-4" id="faq" role="tabpanel">
					<ul role="list" class="divide-y divide-gray-200 dark:divide-gray-700">
						{dashData.topSchools.map((s: any) => (
						<li class="py-3 sm:py-4">
							<div class="flex items-center justify-between">
								<div class="flex items-center min-w-0">
									<div class="flex-shrink-0 w-10 h-10 bg-primary-100 rounded-full flex items-center justify-center dark:bg-primary-900">
										<svg class="w-6 h-6 text-primary-600 dark:text-primary-300" fill="currentColor" viewBox="0 0 20 20"><path d="M10.394 2.08a1 1 0 00-.788 0l-7 3a1 1 0 000 1.84L5.25 8.051v.75a1 1 0 00.553.894l2 1a1 1 0 00.894 0l2-1a1 1 0 00.553-.894v-.75l2.644-1.13a1 1 0 000-1.84l-7-3zM7 10.051l-3.477-1.49L7 7.072V10.051zM10.394 13.08a1 1 0 00-.788 0l-7 3a1 1 0 000 1.84l7 3a1 1 0 00.788 0l7-3a1 1 0 000-1.84l-7-3zM15.586 15l-2.592-1.11a1 1 0 00-.894 0L9.5 15.051V18.1l3.477 1.49L15.586 18.1V15z"></path></svg>
									</div>
									<div class="ml-3">
										<p class="font-medium text-gray-900 truncate dark:text-white">{s.name || s.organization || 'School'}</p>
									</div>
								</div>
								<div class="inline-flex items-center text-base font-semibold text-gray-900 dark:text-white">{s.total_rescued || 0} portions</div>
							</div>
						</li>
						))}
					</ul>
				</div>
				<div class="hidden pt-4" id="about" role="tabpanel">
					<ul role="list" class="divide-y divide-gray-200 dark:divide-gray-700">
						{dashData.topVolunteers.map((v: any) => (
						<li class="py-3 sm:py-4">
							<div class="flex items-center space-x-4">
								<div class="flex-shrink-0"><img class="w-8 h-8 rounded-full" src={v.avatar || `https://ui-avatars.com/api/?name=${encodeURIComponent(v.name || v.email || 'User')}&background=random`} alt="Volunteer image" /></div>
								<div class="flex-1 min-w-0">
									<p class="font-medium text-gray-900 truncate dark:text-white">{v.name || 'Volunteer'}</p>
									<p class="text-sm text-gray-500 truncate dark:text-gray-400">{v.email}</p>
								</div>
								<div class="inline-flex items-center text-base font-semibold text-gray-900 dark:text-white">{v.points || 0} pts</div>
							</div>
						</li>
						))}
					</ul>
				</div>
			</div>
		</div>
	</div>

	<!-- Section Header -->
	<div class="mt-4 mb-4">
		<h2 class="text-xl font-bold text-gray-900 dark:text-white uppercase tracking-tight">MBG Total Rescued</h2>
	</div>

	<div class="grid w-full grid-cols-1 gap-4 mt-4 xl:grid-cols-2 2xl:grid-cols-3 pb-10">
		<div class="items-center justify-between p-4 bg-white border border-gray-200 rounded-lg shadow-sm sm:flex dark:border-gray-700 sm:p-6 dark:bg-gray-800">
			<div class="w-full">
				<h3 class="text-base font-normal text-gray-500 dark:text-gray-400">Active Schools</h3>
				<span class="text-2xl font-bold leading-none text-gray-900 sm:text-3xl dark:text-white">{dashData.activeSchools}</span>
				<p class="flex items-center text-base font-normal text-gray-500 dark:text-gray-400">
					All registered schools
				</p>
			</div>
			<div class="w-full" id="new-products-chart"></div>
		</div>
		<div class="items-center justify-between p-4 bg-white border border-gray-200 rounded-lg shadow-sm sm:flex dark:border-gray-700 sm:p-6 dark:bg-gray-800">
			<div class="w-full">
				<h3 class="text-base font-normal text-gray-500 dark:text-gray-400">Rescue Volunteers</h3>
				<span class="text-2xl font-bold leading-none text-gray-900 sm:text-3xl dark:text-white">{dashData.totalVolunteers}</span>
				<p class="flex items-center text-base font-normal text-gray-500 dark:text-gray-400">
					All registered receivers
				</p>
			</div>
			<div class="w-full" id="week-signups-chart"></div>
		</div>
	</div>
</div>

<script define:vars={{ chartDataJson: JSON.stringify(dashData?.chartData || null) }}>
	try {
		var parsed = JSON.parse(chartDataJson);
		if (parsed) {
			window.CHART_DATA = parsed;
		}
	} catch(e) {}
</script>
<script src="./DashBoard.client.ts"></script>

<style is:global>
	#main-chart {
		min-height: 420px;
	}
	#new-products-chart, #week-signups-chart {
		min-height: 140px;
	}
	.apexcharts-canvas {
		user-select: none;
	}
</style>
