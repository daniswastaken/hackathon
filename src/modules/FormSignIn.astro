---
import { asset, url } from '../lib/data.js';
import mbgLogo from '../assets/mbg-rn.svg';
---

<div
	class="w-full flex flex-col items-center justify-center px-6 pt-8 mx-auto pt:mt-0 dark:bg-gray-900"
>
	<a
		href="/"
		class="flex items-center justify-center mb-8 text-2xl font-semibold lg:mb-10 dark:text-white"
	>
		<img src={mbgLogo} alt="MBG RN Logo" class="mr-4 h-11" width="44" height="44" />
		<span>MBG Rescue</span>
	</a>
	<!-- Card -->
	<div
		class="w-full max-w-xl p-6 space-y-8 sm:p-8 bg-white rounded-lg shadow dark:bg-gray-800"
	>
		<h2 class="text-2xl font-bold text-gray-900 dark:text-white">
			Masuk ke platform
		</h2>
		<form class="mt-8 space-y-6" action="#">
			<div>
				<label
					for="email"
					class="block mb-2 text-sm font-medium text-gray-900 dark:text-white"
					>Email Anda</label
				>
				<input
					type="email"
					name="email"
					id="email"
					class="bg-gray-50 border border-gray-300 text-gray-900 sm:text-sm rounded-lg focus:ring-primary-500 focus:border-primary-500 block w-full p-2.5 dark:bg-gray-700 dark:border-gray-600 dark:placeholder-gray-400 dark:text-white dark:focus:ring-primary-500 dark:focus:border-primary-500"
					placeholder="nama@perusahaan.com"
					required
				/>
			</div>
			<div>
				<label
					for="password"
					class="block mb-2 text-sm font-medium text-gray-900 dark:text-white"
					>Kata sandi Anda</label
				>
				<input
					type="password"
					name="password"
					id="password"
					placeholder="••••••••"
					class="bg-gray-50 border border-gray-300 text-gray-900 sm:text-sm rounded-lg focus:ring-primary-500 focus:border-primary-500 block w-full p-2.5 dark:bg-gray-700 dark:border-gray-600 dark:placeholder-gray-400 dark:text-white dark:focus:ring-primary-500 dark:focus:border-primary-500"
					required
				/>
			</div>
			<button
				type="submit"
				class="w-full px-5 py-3 text-base font-medium text-center text-white bg-primary-700 rounded-lg hover:bg-primary-800 focus:ring-4 focus:ring-primary-300 sm:w-auto dark:bg-primary-600 dark:hover:bg-primary-700 dark:focus:ring-primary-800"
				>Masuk ke akun Anda</button
			>
			<div class="text-sm font-medium text-gray-500 dark:text-gray-400">
				Belum punya akun? <a
					href="/authentication/sign-up"
					class="text-primary-700 hover:underline dark:text-primary-500"
					>Buat akun</a
				>
			</div>
		</form>
	</div>
</div>

<script>
	const form = document.querySelector('form');
	form?.addEventListener('submit', async (e) => {
		e.preventDefault();
		const formData = new FormData(form);
		const email = formData.get('email');
		const password = formData.get('password');
		const remember = formData.get('remember');

		try {
			const res = await fetch('/api/auth?type=login', {
				method: 'POST',
				headers: { 'Content-Type': 'application/json' },
				body: JSON.stringify({ email, password })
			});
			const text = await res.text();
			console.log('Raw API response:', text);
			const data = text ? JSON.parse(text) : {};
			if (res.ok) {
				// Success
				localStorage.setItem('user', JSON.stringify(data.user));
				window.showToast('Berhasil masuk!', 'success');
				setTimeout(() => {
					window.location.href = '/dashboard';
				}, 1000);
			} else {
				window.showToast(data.error || 'Gagal masuk', 'error');
			}
		} catch (error) {
			console.error('Error:', error);
			window.showToast('Terjadi kesalahan: ' + (error instanceof Error ? error.message : String(error)), 'error');
		}
	});
</script>
