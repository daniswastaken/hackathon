---
import LayoutSidebar from '../../app/LayoutSidebar.astro';

// We fetch the data from our newly created API endpoint
let availableFood = [];
try {
	const response = await fetch(new URL('/api/food', Astro.url));
	if (response.ok) {
		availableFood = await response.json();
	}
} catch (e) {
	console.error('Failed to fetch food listings:', e);
}
---

<LayoutSidebar>
	<div class="px-4 pt-6">
		<div class="mb-4">
			<h1 class="text-xl font-semibold text-gray-900 sm:text-2xl dark:text-white">Live Food Rescue Feed</h1>
		</div>

		<div class="grid grid-cols-1 gap-4 md:grid-cols-2 xl:grid-cols-3" id="feed-container">
			{availableFood.length === 0 ? (
				<p class="text-gray-500 dark:text-gray-400">No food listings available at the moment.</p>
			) : (
				availableFood.map((item: any) => (
					<div class="p-4 bg-white border border-gray-200 rounded-lg shadow-sm dark:border-gray-700 dark:bg-gray-800 flex flex-col justify-between">
						<div>
							<div class="flex items-center justify-between mb-3">
								<span class={`text-xs font-medium px-2.5 py-0.5 rounded border ${item.status === 'available' ? 'bg-green-50 text-green-700 border-green-200 dark:bg-green-900/30 dark:text-green-300 dark:border-green-800' : 'bg-gray-50 text-gray-700 border-gray-200 dark:bg-gray-700 dark:text-gray-300 dark:border-gray-600'}`}>
									{item.status.toUpperCase()}
								</span>
								<span class="text-sm font-medium text-gray-500 dark:text-gray-400">Deadline: {item.pickup_time || 'N/A'}</span>
							</div>
							<h3 class="text-lg font-bold text-gray-900 dark:text-white mb-1">{item.school || item.organization || 'Unknown Provider'}</h3>
							<p class="text-sm text-gray-600 dark:text-gray-300 mb-4">{item.title}</p>
							
							<div class="space-y-2 mb-6">
								<div class="flex items-center text-sm text-gray-500 dark:text-gray-400">
									<i class="ph-bold ph-package mr-2"></i>
									{item.quantity_portions || 'N/A'} portions
								</div>
								<div class="flex items-center text-sm text-gray-500 dark:text-gray-400">
									<i class="ph-bold ph-map-pin mr-2"></i>
									{item.location || item.address || 'Location not specified'}
								</div>
							</div>
						</div>

						<div class="flex flex-col space-y-2">
							{item.status === 'available' && (
								<a href={`https://www.google.com/maps/search/?api=1&query=${item.latitude},${item.longitude}`} target="_blank" class="w-full text-gray-900 bg-white border border-gray-300 hover:bg-gray-100 focus:ring-4 focus:ring-gray-100 font-medium rounded-lg text-sm px-5 py-2.5 text-center dark:bg-gray-800 dark:text-white dark:border-gray-600 dark:hover:bg-gray-700">
									Open Map
								</a>
							)}
							{item.status === 'available' && (
								<button 
									onclick={`const user = JSON.parse(localStorage.getItem('user') || '{}'); fetch('/api/reserve', { method: 'POST', body: JSON.stringify({ listingId: ${item.id}, userId: user.id }) }).then(r => r.json()).then(data => data.success ? (alert('Reserved!'), location.reload()) : alert('Failed: ' + data.error))`}
									class="w-full text-white bg-primary-700 hover:bg-primary-800 focus:ring-4 focus:ring-primary-300 font-medium rounded-lg text-sm px-5 py-2.5 dark:bg-primary-600 dark:hover:bg-primary-700 focus:outline-none dark:focus:ring-primary-800">
									Reserve
								</button>
							)}
							<script is:inline define:vars={{ providerId: item.provider_id, listingId: item.id }}>
								const user = JSON.parse(localStorage.getItem('user') || '{}');
								if (user && user.id == providerId) {
									const btn = document.getElementById('delete-btn-' + listingId);
									if (btn) btn.classList.remove('hidden');
								}
							</script>
							<button 
								id={`delete-btn-${item.id}`}
								onclick={`fetch('/api/rescue', { method: 'POST', body: JSON.stringify({ action: 'delete', listingId: ${item.id} }) }).then(r => r.ok ? location.reload() : alert('Failed'))`}
								class="hidden w-full text-white bg-red-700 hover:bg-red-800 focus:ring-4 focus:ring-red-300 font-medium rounded-lg text-sm px-5 py-2.5 dark:bg-red-600 dark:hover:bg-red-700 focus:outline-none dark:focus:ring-red-800">
								Delete Post
							</button>
						</div>
					</div>
				))
			)}
		</div>
	</div>
</LayoutSidebar>
