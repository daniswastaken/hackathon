---
import LayoutSidebar from '../../app/LayoutSidebar.astro';
---

<LayoutSidebar>
	<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" integrity="sha256-p4NxAoJBhIIN+hmNHrzRCf9tD/miZyoHS5obTRR9BMY=" crossorigin="" />
	
	<div class="px-4 pt-6 pb-12">
		<div class="p-4 bg-white border border-gray-200 rounded-lg shadow-sm dark:border-gray-700 sm:p-6 dark:bg-gray-800">
			<!-- Card header -->
			<div class="items-center justify-between lg:flex border-b border-gray-200 dark:border-gray-700 pb-4 mb-6">
				<div class="mb-4 lg:mb-0">
					<h3 class="mb-2 text-xl font-bold text-gray-900 dark:text-white">Post Available MBG Food</h3>
					<span class="text-base font-normal text-gray-500 dark:text-gray-400">Notify volunteers and people in need about surplus food at your school.</span>
				</div>
			</div>
			
			<form id="post-surplus-form" class="space-y-6">
				<div class="grid grid-cols-1 gap-6 md:grid-cols-2">
					<div class="space-y-4">
						<div>
							<label for="food_type" class="block mb-2 text-sm font-medium text-gray-900 dark:text-white">Food Type</label>
							<input type="text" id="food_type" name="food_type" class="bg-gray-50 border border-gray-300 text-gray-900 text-sm rounded-lg focus:ring-primary-500 focus:border-primary-500 block w-full p-2.5 dark:bg-gray-700 dark:border-gray-600 dark:placeholder-gray-400 dark:text-white" placeholder="e.g. Nasi Kuning, Side Dishes" required>
						</div>
						<div class="grid grid-cols-2 gap-4">
							<div>
								<label for="quantity" class="block mb-2 text-sm font-medium text-gray-900 dark:text-white">Quantity (Portions)</label>
								<input type="number" id="quantity" name="quantity" class="bg-gray-50 border border-gray-300 text-gray-900 text-sm rounded-lg focus:ring-primary-500 focus:border-primary-500 block w-full p-2.5 dark:bg-gray-700 dark:border-gray-600 dark:placeholder-gray-400 dark:text-white" placeholder="20" required>
							</div>
							<div lang="id">
								<label for="pickup_time" class="block mb-2 text-sm font-medium text-gray-900 dark:text-white">Pickup Deadline</label>
								<input type="time" id="pickup_time" name="pickup_time" lang="id" class="bg-gray-50 border border-gray-300 text-gray-900 text-sm rounded-lg focus:ring-primary-500 focus:border-primary-500 block w-full p-2.5 dark:bg-gray-700 dark:border-gray-600 dark:text-white" required>
							</div>
						</div>
						<div>
							<label for="category" class="block mb-2 text-sm font-medium text-gray-900 dark:text-white">Intended Use / Category</label>
							<select id="category" name="category" class="bg-gray-50 border border-gray-300 text-gray-900 text-sm rounded-lg focus:ring-primary-500 focus:border-primary-500 block w-full p-2.5 dark:bg-gray-700 dark:border-gray-600 dark:placeholder-gray-400 dark:text-white" required>
								<option value="consumption">Human Consumption (Safe to Eat)</option>
								<option value="farm">Farm Feed / Bio-fertilizer (Waste)</option>
							</select>
						</div>
						<div>
							<label for="location_name" class="block mb-2 text-sm font-medium text-gray-900 dark:text-white">Pickup Point (Specific Area)</label>
							<input type="text" id="location_name" name="location_name" class="bg-gray-50 border border-gray-300 text-gray-900 text-sm rounded-lg focus:ring-primary-500 focus:border-primary-500 block w-full p-2.5 dark:bg-gray-700 dark:border-gray-600 dark:placeholder-gray-400 dark:text-white" placeholder="e.g. Front Gate / Canteen" required>
						</div>
					</div>

					<div class="space-y-4 h-full flex flex-col">
						<label class="block text-sm font-medium text-gray-900 dark:text-white">Pin Location on Map</label>
						<div id="map" class="w-full h-64 md:h-96 rounded-lg border border-gray-300 dark:border-gray-600 z-0 shadow-sm"></div>
						<div class="flex justify-end">
							<button type="button" id="locate-me" class="inline-flex items-center px-3 py-2 text-sm font-medium text-center text-white bg-primary-700 rounded-lg hover:bg-primary-800 focus:ring-4 focus:ring-primary-300 dark:bg-primary-600 dark:hover:bg-primary-700 dark:focus:ring-primary-800">
								<i class="ph-bold ph-map-pin mr-2"></i>
								Use My Current Location
							</button>
						</div>
					</div>
				</div>

				<div class="grid grid-cols-1 gap-6 md:grid-cols-2">
					<div>
						<label for="full_address" class="flex items-center mb-2 text-sm font-medium text-gray-900 dark:text-white">
							<i class="ph-bold ph-map-pin mr-2 text-gray-400"></i>
							Full Street Address (Auto-filled)
						</label>
						<textarea id="full_address" name="full_address" rows="3" class="bg-gray-50 border border-gray-300 text-gray-900 text-sm rounded-lg focus:ring-primary-500 focus:border-primary-500 block w-full p-2.5 dark:bg-gray-700 dark:border-gray-600 dark:placeholder-gray-400 dark:text-white" placeholder="Pin a location to fill address..." required></textarea>
						<p id="geocoding-status" class="mt-2 text-xs font-medium text-gray-500 dark:text-gray-400"></p>
					</div>
					<div>
						<label for="description" class="block mb-2 text-sm font-medium text-gray-900 dark:text-white">Additional Instructions</label>
						<textarea id="description" name="description" rows="3" class="bg-gray-50 border border-gray-300 text-gray-900 text-sm rounded-lg focus:ring-primary-500 focus:border-primary-500 block w-full p-2.5 dark:bg-gray-700 dark:border-gray-600 dark:placeholder-gray-400 dark:text-white" placeholder="e.g. Please bring your own containers..."></textarea>
					</div>
				</div>

				<div class="hidden">
					<input type="text" id="lat" name="lat">
					<input type="text" id="lng" name="lng">
				</div>

				<div class="flex items-center space-x-4">
					<button type="submit" class="text-white bg-primary-700 hover:bg-primary-800 focus:ring-4 focus:outline-none focus:ring-primary-300 font-medium rounded-lg text-sm px-5 py-2.5 text-center dark:bg-primary-600 dark:hover:bg-primary-700 dark:focus:ring-primary-800">
						Broadcast Rescue Notification
					</button>
				</div>
			</form>
		</div>
	</div>

	<script>
		document.addEventListener('DOMContentLoaded', () => {
			const form = document.getElementById('post-surplus-form');
			if (form) {
				form.addEventListener('submit', async (e) => {
					e.preventDefault();
					const userStr = localStorage.getItem('user');
					if (!userStr) {
						alert('You must be logged in as a provider to post surplus!');
						return;
					}
					const user = JSON.parse(userStr);
					if (user.role !== 'provider') {
						alert('Only school providers can post surplus food!');
						return;
					}

					const fd = new FormData(form as HTMLFormElement);
					
					const payload = {
						provider_id: user.id,
						title: fd.get('food_type'),
						quantity_portions: parseInt(fd.get('quantity') as string, 10),
						pickup_time: fd.get('pickup_time'),
						category: fd.get('category'),
						location: fd.get('location_name'),
						address: fd.get('full_address'),
						description: fd.get('description'),
						latitude: parseFloat(fd.get('lat') as string),
						longitude: parseFloat(fd.get('lng') as string)
					};

					try {
						const res = await fetch('/api/food', {
							method: 'POST',
							headers: { 'Content-Type': 'application/json' },
							body: JSON.stringify(payload)
						});
						if (res.ok) {
							alert('Food listing successfully broadcasted!');
							window.location.href = '/rescue/feed';
						} else {
							const errorData = await res.json();
							alert('Error: ' + errorData.error);
						}
					} catch (err) {
						console.error(err);
						alert('Failed to post listing.');
					}
				});
			}
		});
	</script>

	<!-- Leaflet JS -->
	<script is:inline src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js" integrity="sha256-20nQCchB9co0qIjJZRGuk2/Z9VM+kNiyxNV1lvTlZBo=" crossorigin=""></script>
	
	<script is:inline>
		document.addEventListener('DOMContentLoaded', function() {
			const initialLat = -6.2088;
			const initialLng = 106.8456;
			
			const map = L.map('map').setView([initialLat, initialLng], 13);
			
			L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
				attribution: '&copy; OpenStreetMap contributors'
			}).addTo(map);

			let marker;

			map.on('click', function(e) {
				updateMarker(e.latlng);
			});

			document.getElementById('locate-me').addEventListener('click', function() {
				console.log('Locate me clicked');
				if (!navigator.geolocation) {
					alert('Geolocation is not supported by your browser');
					return;
				}

				navigator.geolocation.getCurrentPosition((position) => {
					const { latitude, longitude } = position.coords;
					const latlng = L.latLng(latitude, longitude);
					map.setView(latlng, 17);
					updateMarker(latlng);
				}, (error) => {
					alert('Unable to retrieve location: ' + error.message);
				});
			});

			function updateMarker(latlng) {
				if (marker) {
					marker.setLatLng(latlng);
				} else {
					marker = L.marker(latlng, { draggable: true }).addTo(map);
					marker.on('dragend', function(event) {
						const position = marker.getLatLng();
						handleLocationChange(position.lat, position.lng);
					});
				}
				handleLocationChange(latlng.lat, latlng.lng);
			}

			async function handleLocationChange(lat, lng) {
				document.getElementById('lat').value = lat.toFixed(6);
				document.getElementById('lng').value = lng.toFixed(6);
				
				const statusEl = document.getElementById('geocoding-status');
				statusEl.textContent = 'Fetching address...';
				
				try {
					const response = await fetch(`https://nominatim.openstreetmap.org/reverse?format=json&lat=${lat}&lon=${lng}&zoom=18&addressdetails=1`, {
						headers: { 'Accept-Language': 'id,en' }
					});
					const data = await response.json();
					
					if (data && data.display_name) {
						document.getElementById('full_address').value = data.display_name;
						statusEl.textContent = '✓ Address matched';
					} else {
						statusEl.textContent = '⚠ Location pinned, street address not found';
					}
				} catch (error) {
					statusEl.textContent = '⚠ Address fetch failed';
				}
			}
		});
	</script>
</LayoutSidebar>
