---
import LayoutSidebar from '../../app/LayoutSidebar.astro';
---

<LayoutSidebar>
	<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" integrity="sha256-p4NxAoJBhIIN+hmNHrzRCf9tD/miZyoHS5obTRR9BMY=" crossorigin="" />
	
	<div class="px-4 pt-6 pb-12">
		<div class="p-4 bg-white border border-gray-200 rounded-lg shadow-sm dark:border-gray-700 sm:p-6 dark:bg-gray-800">
			<!-- Card header -->
			<div class="items-center justify-between lg:flex border-b border-gray-200 dark:border-gray-700 pb-4 mb-6">
				<div class="mb-4 lg:mb-0">
					<h3 class="mb-2 text-xl font-bold text-gray-900 dark:text-white">Post Surplus MBG</h3>
					<span class="text-base font-normal text-gray-500 dark:text-gray-400">Beritahu relawan dan masyarakat yang membutuhkan mengenai surplus makanan di sekolah Anda.</span>
				</div>
			</div>
			
			<form id="post-surplus-form" class="space-y-6">
				<div class="grid grid-cols-1 gap-6 md:grid-cols-2">
					<div class="space-y-4">
						<div>
							<label for="food_type" class="block mb-2 text-sm font-medium text-gray-900 dark:text-white">Jenis Makanan</label>
							<input type="text" id="food_type" name="food_type" class="bg-gray-50 border border-gray-300 text-gray-900 text-sm rounded-lg focus:ring-primary-500 focus:border-primary-500 block w-full p-2.5 dark:bg-gray-700 dark:border-gray-600 dark:placeholder-gray-400 dark:text-white" placeholder="Contoh: Nasi Kuning, Lauk Pauk" required>
						</div>
						<div class="grid grid-cols-2 gap-4">
							<div>
								<label for="quantity" class="block mb-2 text-sm font-medium text-gray-900 dark:text-white">Kuantitas (Porsi)</label>
								<input type="number" id="quantity" name="quantity" class="bg-gray-50 border border-gray-300 text-gray-900 text-sm rounded-lg focus:ring-primary-500 focus:border-primary-500 block w-full p-2.5 dark:bg-gray-700 dark:border-gray-600 dark:placeholder-gray-400 dark:text-white" placeholder="20" required>
							</div>
							<div lang="id">
								<label for="pickup_time" class="block mb-2 text-sm font-medium text-gray-900 dark:text-white">Batas Waktu Pengambilan</label>
								<input type="time" id="pickup_time" name="pickup_time" lang="id" class="bg-gray-50 border border-gray-300 text-gray-900 text-sm rounded-lg focus:ring-primary-500 focus:border-primary-500 block w-full p-2.5 dark:bg-gray-700 dark:border-gray-600 dark:text-white" required>
							</div>
						</div>
						<div>
							<label for="category" class="block mb-2 text-sm font-medium text-gray-900 dark:text-white">Tujuan Penggunaan / Kategori</label>
							<select id="category" name="category" class="bg-gray-50 border border-gray-300 text-gray-900 text-sm rounded-lg focus:ring-primary-500 focus:border-primary-500 block w-full p-2.5 dark:bg-gray-700 dark:border-gray-600 dark:placeholder-gray-400 dark:text-white" required>
								<option value="consumption">Konsumsi (Aman Dimakan)</option>
								<option value="farm">Pakan Ternak / Bio-fertilizer (Limbah)</option>
							</select>
						</div>
						<div>
							<label for="location_name" class="block mb-2 text-sm font-medium text-gray-900 dark:text-white">Titik Pengambilan (Area Spesifik)</label>
							<input type="text" id="location_name" name="location_name" class="bg-gray-50 border border-gray-300 text-gray-900 text-sm rounded-lg focus:ring-primary-500 focus:border-primary-500 block w-full p-2.5 dark:bg-gray-700 dark:border-gray-600 dark:placeholder-gray-400 dark:text-white" placeholder="Contoh: Gerbang Depan / Kantin" required>
						</div>
					</div>

					<div class="space-y-4 h-full flex flex-col">
						<label class="block text-sm font-medium text-gray-900 dark:text-white">Tandai Lokasi di Peta</label>
						<div id="map" class="w-full h-64 md:h-96 rounded-lg border border-gray-300 dark:border-gray-600 z-0 shadow-sm"></div>
						<div class="flex justify-end">
							<button type="button" id="locate-me" class="inline-flex items-center px-3 py-2 text-sm font-medium text-center text-white bg-primary-700 rounded-lg hover:bg-primary-800 focus:ring-4 focus:ring-primary-300 dark:bg-primary-600 dark:hover:bg-primary-700 dark:focus:ring-primary-800">
								<i class="ph-bold ph-map-pin mr-2"></i>
								Gunakan Lokasi Saat Ini
							</button>
						</div>
					</div>
				</div>

				<div class="grid grid-cols-1 gap-6 md:grid-cols-2">
					<div>
						<label for="full_address" class="flex items-center mb-2 text-sm font-medium text-gray-900 dark:text-white">
							<i class="ph-bold ph-map-pin mr-2 text-gray-400"></i>
							Alamat Lengkap (Terisi Otomatis)
						</label>
						<textarea id="full_address" name="full_address" rows="3" class="bg-gray-50 border border-gray-300 text-gray-900 text-sm rounded-lg focus:ring-primary-500 focus:border-primary-500 block w-full p-2.5 dark:bg-gray-700 dark:border-gray-600 dark:placeholder-gray-400 dark:text-white" placeholder="Tandai lokasi untuk mengisi alamat..." required></textarea>
						<p id="geocoding-status" class="mt-2 text-xs font-medium text-gray-500 dark:text-gray-400"></p>
					</div>
					<div>
						<label for="description" class="block mb-2 text-sm font-medium text-gray-900 dark:text-white">Instruksi Tambahan</label>
						<textarea id="description" name="description" rows="3" class="bg-gray-50 border border-gray-300 text-gray-900 text-sm rounded-lg focus:ring-primary-500 focus:border-primary-500 block w-full p-2.5 dark:bg-gray-700 dark:border-gray-600 dark:placeholder-gray-400 dark:text-white" placeholder="Contoh: Harap bawa wadah sendiri..."></textarea>
					</div>
				</div>

				<div class="hidden">
					<input type="text" id="lat" name="lat">
					<input type="text" id="lng" name="lng">
				</div>

				<div class="flex items-center space-x-4">
					<button type="submit" class="text-white bg-primary-700 hover:bg-primary-800 focus:ring-4 focus:outline-none focus:ring-primary-300 font-medium rounded-lg text-sm px-5 py-2.5 text-center dark:bg-primary-600 dark:hover:bg-primary-700 dark:focus:ring-primary-800">
						Kirim Notifikasi Rescue
					</button>
				</div>
			</form>
		</div>
	</div>

	<script>
		document.addEventListener('DOMContentLoaded', () => {
			const form = document.getElementById('post-surplus-form');
			if (form) {
				form.addEventListener('submit', async (e) => {
					e.preventDefault();
					const userStr = localStorage.getItem('user');
					if (!userStr) {
						window.showToast('Anda harus masuk sebagai penyedia untuk memposting surplus!', 'error');
						return;
					}
					const user = JSON.parse(userStr);
					if (user.role !== 'provider' && user.role !== 'school') {
						window.showToast('Hanya pihak sekolah yang dapat memposting surplus makanan!', 'error');
						return;
					}
					const payload = {
					  provider_id: user.id,
					  title: document.getElementById('food_type').value,
					  description: document.getElementById('description').value,
					  category: document.getElementById('category').value,
					  quantity_portions: Number(document.getElementById('quantity').value),
					  pickup_time: document.getElementById('pickup_time').value,
					  location: document.getElementById('location_name').value,
					  address: document.getElementById('full_address').value,
					  latitude: parseFloat(document.getElementById('lat').value),
					  longitude: parseFloat(document.getElementById('lng').value)
					};
					try {
						const res = await fetch('/api/food', {
							method: 'POST',
							headers: { 'Content-Type': 'application/json' },
							body: JSON.stringify(payload)
						});
						if (res.ok) {
							window.showToast('Listing makanan berhasil dikirim!', 'success');
							setTimeout(() => {
								window.location.href = '/rescue/feed';
							}, 1500);
						} else {
							const errorData = await res.json();
							window.showToast('Error: ' + errorData.error, 'error');
						}
					} catch (err) {
						console.error(err);
						window.showToast('Gagal memposting listing.', 'error');
					}
				});
			}
		});
	</script>

	<!-- Leaflet JS -->
	<script is:inline src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js" integrity="sha256-20nQCchB9co0qIjJZRGuk2/Z9VM+kNiyxNV1lvTlZBo=" crossorigin=""></script>
	
	<script is:inline>
		document.addEventListener('DOMContentLoaded', function() {
			const initialLat = -6.2088;
			const initialLng = 106.8456;
			
			const map = L.map('map').setView([initialLat, initialLng], 13);
			
			L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
				attribution: '&copy; OpenStreetMap contributors'
			}).addTo(map);

			let marker;

			map.on('click', function(e) {
				updateMarker(e.latlng);
			});

			document.getElementById('locate-me').addEventListener('click', function() {
				console.log('Locate me clicked');
				if (!navigator.geolocation) {
					window.showToast('Geolokasi tidak didukung oleh browser Anda', 'error');
					return;
				}

				navigator.geolocation.getCurrentPosition((position) => {
					const { latitude, longitude } = position.coords;
					const latlng = L.latLng(latitude, longitude);
					map.setView(latlng, 17);
					updateMarker(latlng);
				}, (error) => {
					window.showToast('Tidak dapat memperoleh lokasi: ' + error.message, 'error');
				});
			});

			function updateMarker(latlng) {
				if (marker) {
					marker.setLatLng(latlng);
				} else {
					marker = L.marker(latlng, { draggable: true }).addTo(map);
					marker.on('dragend', function(event) {
						const position = marker.getLatLng();
						handleLocationChange(position.lat, position.lng);
					});
				}
				handleLocationChange(latlng.lat, latlng.lng);
			}

			async function handleLocationChange(lat, lng) {
				document.getElementById('lat').value = lat.toFixed(6);
				document.getElementById('lng').value = lng.toFixed(6);
				
				const statusEl = document.getElementById('geocoding-status');
				statusEl.textContent = 'Mengambil alamat...';
				
				try {
					const response = await fetch(`https://nominatim.openstreetmap.org/reverse?format=json&lat=${lat}&lon=${lng}&zoom=18&addressdetails=1`, {
						headers: { 'Accept-Language': 'id,en' }
					});
					const data = await response.json();
					
					if (data && data.display_name) {
						document.getElementById('full_address').value = data.display_name;
						statusEl.textContent = '✓ Alamat sesuai';
					} else {
						statusEl.textContent = '⚠ Lokasi ditandai, alamat jalan tidak ditemukan';
					}
				} catch (error) {
					statusEl.textContent = '⚠ Gagal mengambil alamat';
				}
			}
		});
	</script>
</LayoutSidebar>
